{
  "routes": [],
  "navigationFallback": {
    "rewrite": "index.html"
  },
  "responseOverrides": {},
  "globalHeaders": {},
  "mimeTypes": {},
  "headers": [
    {
      "source": "index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        }
      ]
    }
  ]
}
